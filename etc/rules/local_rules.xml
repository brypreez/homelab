<group name="kubernetes,syscheck,">

  <rule id="110005" level="10">
    <field name="syscheck.path">^/etc/kubernetes/manifests/.*</field>
    <description>SECURITY ALERT: Critical K8s Manifest Modified: $(syscheck.path)</description>
    <group>syscheck,kubernetes_security,pci_dss_11.5</group>
  </rule>

  <rule id="110001" level="10">
    <if_sid>5402</if_sid>
    <match>kubectl delete</match>
    <description>Kubernetes Resource Deleted by $(srcuser)</description>
    <group>kubernetes_audit,pci_dss_10.2.5,</group>
  </rule>

</group>